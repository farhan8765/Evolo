{
    "redirects": [
      {
        "source": "/:path((?!.*\\.).*)",
        "has": [
          {
            "type": "query",
            "key": "k"
          }
        ],
        "destination": "/:path",
        "permanent": true
      }
    ],
  "rewrites": [
    {
      "source": "/((?!images/)(?!static/)(?!assets/).*)",
      "destination": "/index.html"
    }
  ],
    "headers": [
      {
        "source": "/static/js/:path*",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          },
          {
            "key": "Vercel-CDN-Cache-Control",
            "value": "max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "/static/css/:path*",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          },
          {
            "key": "Vercel-CDN-Cache-Control",
            "value": "max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "/static/media/:path*",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "/images/:path*",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "/index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          },
          {
            "key": "Vercel-CDN-Cache-Control",
            "value": "s-maxage=60, stale-while-revalidate=300"
          }
        ]
      },
      {
        "source": "/",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          },
          {
            "key": "Vercel-CDN-Cache-Control",
            "value": "s-maxage=60, stale-while-revalidate=300"
          }
        ]
      },
      {
        "source": "/(.*)",
        "headers": [
          {
            "key": "X-Frame-Options",
            "value": "DENY"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "X-XSS-Protection",
            "value": "1; mode=block"
          }
        ]
      }
    ]
}