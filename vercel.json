{
    "redirects": [
      {
        "source": "/:path((?!.*\\.).*)",
        "has": [
          {
            "type": "query",
            "key": "k"
          }
        ],
        "destination": "/:path",
        "permanent": true
      }
    ],
  "rewrites": [
    {
      "source": "/((?!images/)(?!static/)(?!assets/).*)",
      "destination": "/index.html"
    }
  ],
    "headers": [
      {
        "source": "/static/(.*)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "/images/(.*)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "/(.*\\.(js|css|woff2|woff|ttf|eot|ico|png|jpg|jpeg|gif|webp|svg))",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "/index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "/(.*)",
        "headers": [
          {
            "key": "X-Frame-Options",
            "value": "DENY"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "X-XSS-Protection",
            "value": "1; mode=block"
          }
        ]
      }
    ]
}